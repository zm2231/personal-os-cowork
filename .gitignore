# PersonalOS for Cowork - Git Ignore File

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Obsidian vault config (per-user, not template)
.obsidian/

# User-specific data (DO NOT commit user preferences!)
# PersonalOS populates these during onboarding — they contain personal data
# Keep a local copy; do not commit to forks of this template
personal-os/logs/sessions/
personal-os/context/notifications.md

# Legacy session data
*.session.json
user-adaptations/
user-shortcuts/
user-automations/

# Temporary files
*.tmp
*.temp
*.log
*~

# Backup files
*.bak
*.backup
*.old
