# PersonalOS for Cowork - Git Ignore File

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# User-specific data (DO NOT commit user preferences!)
# PersonalOS adapts to users - keep their data local
sessions/
*.session.json
user-adaptations/
user-shortcuts/
user-automations/

# Temporary files
*.tmp
*.temp
*.log
*~

# Backup files
*.bak
*.backup
*.old
